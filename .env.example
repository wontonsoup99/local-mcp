# --- Remote MCP (OpenShop) ---
MCP_URL=https://mcp.openshopgo.com/sandbox/mcp
MCP_TRANSPORT=streamable-http
# MCP_TRANSPORT=sse

# Prefer refresh (stops hourly expiry pain): set MCP_REFRESH_TOKEN from oauth/token response.
# Then MCP_BEARER_TOKEN is optional (used only if MCP_REFRESH_TOKEN is unset).
# MCP_REFRESH_TOKEN=
# MCP_OAUTH_CLIENT_ID=openshop-claude
# MCP_OAUTH_TOKEN_URL=https://mcp.openshopgo.com/oauth/token
# MCP_REFRESH_TOKEN_FILE=/path/to/refresh.txt  # optional: rotated refresh written here

# Static access token if you are not using MCP_REFRESH_TOKEN (~1h lifetime)
MCP_BEARER_TOKEN=replace-with-your-token
# MCP_AUTH_STYLE=raw

# Same store slug as on mcp.openshopgo.com (sent as X-Store-Slug)
MCP_STORE_SLUG=your-store-slug

# If the MCP page works in a browser but headers alone get 401, copy the Cookie line from
# DevTools → Network → request to mcp.openshopgo.com → Request Headers.
# Use double quotes if the value has special chars: MCP_COOKIE="activitySessionId=uuid-here"
# MCP_COOKIE=
# Debug: MCP_DISABLE_BEARER=1  # cookie-only test   MCP_DISABLE_STORE_SLUG=1

# Optional extra headers. Note: MCP_BEARER_TOKEN and MCP_STORE_SLUG are applied AFTER this
# JSON so they always win (fixes accidental Authorization overwrite from JSON).
# MCP_HEADERS_JSON={"X-Custom":"value"}

# If OpenShop uses a different slug header than X-Store-Slug:
# MCP_STORE_SLUG_HEADER=X-Store-Slug

# Debug: MCP probe at GET /health/mcp (lists tool names; no secrets)
# EXPOSE_MCP_HEALTHCHECK=1

# --- Ollama (inside Docker Compose, compose sets OLLAMA_BASE_URL to the ollama service) ---
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=llama3.1

# --- Agent HTTP API ---
AGENT_BIND_HOST=0.0.0.0
AGENT_PORT=8080

# Optional persistent default system prompt (used when /chat omits "system")
# Keep this concise and operation-safe for ecommerce actions.
# SYSTEM_PROMPT=You are an ecommerce MCP agent. Read tool schemas first, prefer read tools before writes, and request confirmation before refunds/cancellations.

MAX_TOOL_ROUNDS=16

# --- Open WebUI (optional Docker profile `webui` in deploy/docker-compose.yml) ---
# Compose reads deploy/.env for ${WEBUI_SECRET_KEY} substitution, or pass in the shell:
#   WEBUI_SECRET_KEY="$(openssl rand -hex 32)" docker compose --profile webui up -d
# WEBUI_SECRET_KEY=
